<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/previewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/btnPreviewClose"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:background="#80000000"
        android:src="@drawable/ic_close"
        android:contentDescription="Закрыть" />

    <ImageView
        android:id="@+id/btnPreviewToggle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:padding="14dp"
        android:background="@drawable/select_circle_bg"
        android:src="@drawable/select_circle_checked"
        android:contentDescription="Выбрать" />

    <ImageView
        android:id="@+id/previewCheckIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:layout_margin="30dp"
        android:src="@drawable/ic_check_white"
        android:visibility="gone"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/previewPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:padding="6dp"
        android:background="#80000000"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />
</FrameLayout>
