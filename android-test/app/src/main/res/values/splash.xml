<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash-тема для MainActivity: показывается системой при cold start.
         После загрузки Activity вызывает setTheme(AppTheme) и работает на нём. -->
    <style name="SplashTheme" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
    </style>
</resources>
